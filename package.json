{
	"name": "maskot",
	"version": "1.0.0",
	"description": "Zero-dependency, framework-agnostic input masking library with custom tokens, multi-pattern support, and type-safe presets",
	"type": "module",
	"packageManager": "pnpm@10.11.0",
	"license": "MIT",
	"main": "dist/index.cjs",
	"module": "dist/index.js",
	"types": "dist/index.d.ts",
	"sideEffects": false,
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		},
		"./br": {
			"types": "./dist/presets/br/index.d.ts",
			"import": "./dist/presets/br/index.js",
			"require": "./dist/presets/br/index.cjs"
		}
	},
	"scripts": {
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "eslint src/",
		"format": "prettier src/ --write",
		"build": "vite build",
		"prerelease": "pnpm test && pnpm build",
		"changeset": "changeset",
		"version-packages": "changeset version",
		"release": "pnpm prerelease && changeset publish",
		"prepare": "husky"
	},
	"files": [
		"dist/",
		"package.json",
		"README.md",
		"CHANGELOG.md"
	],
	"author": {
		"name": "Rafael Bernardino",
		"url": "https://github.com/bernardinorafael"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/bernardinorafael/maskot"
	},
	"keywords": [
		"mask",
		"input mask",
		"generic mask",
		"regex mask",
		"multiple mask"
	],
	"lint-staged": {
		"*.ts": [
			"eslint --fix",
			"prettier --write"
		]
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	},
	"devDependencies": {
		"@changesets/cli": "2.30.0",
		"@commitlint/cli": "^19.0.0",
		"@commitlint/config-conventional": "^19.0.0",
		"@eslint/js": "^9.0.0",
		"@ianvs/prettier-plugin-sort-imports": "^4.0.0",
		"eslint": "^9.0.0",
		"husky": "^9.0.0",
		"lint-staged": "^15.0.0",
		"prettier": "^3.0.0",
		"typescript": "^5.5.0",
		"typescript-eslint": "^8.0.0",
		"vite": "^6.0.0",
		"vite-plugin-dts": "^4.0.0",
		"vitest": "^3.0.0"
	}
}
